{
    "name": "itk-dev/rpa-process-overview",
    "description": "RPA Process Overview",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^2.18.2",
        "doctrine/doctrine-migrations-bundle": "^3.7.0",
        "doctrine/orm": "^3.6.6",
        "easycorp/easyadmin-bundle": "^4.29.8",
        "itk-dev/openid-connect-bundle": "^4.2",
        "league/uri-components": "^7.8.1",
        "stof/doctrine-extensions-bundle": "^1.15.3",
        "symfony/asset": "^7.4.8",
        "symfony/asset-mapper": "^7.4.11",
        "symfony/console": "^7.4.11",
        "symfony/dotenv": "^7.4.11",
        "symfony/flex": "^2.10.0",
        "symfony/framework-bundle": "^7.4.11",
        "symfony/mercure-bundle": "^0.3.9",
        "symfony/runtime": "^7.4.12",
        "symfony/security-bundle": "^7.4.12",
        "symfony/translation": "^7.4.10",
        "symfony/twig-bundle": "^7.4.8",
        "symfony/yaml": "^7.4.12",
        "symfonycasts/tailwind-bundle": "^0.11.1",
        "twig/extra-bundle": "^2.12 || ^3.24",
        "twig/twig": "^2.12 || ^3.26.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.52.0",
        "friendsofphp/php-cs-fixer": "^3.95.2",
        "hautelook/alice-bundle": "^2.17.3",
        "nelmio/cors-bundle": "^2.6.1",
        "symfony/debug-bundle": "^7.4.8",
        "symfony/maker-bundle": "^1.67",
        "symfony/stopwatch": "^7.4.8",
        "symfony/web-profiler-bundle": "^7.4.12",
        "vincentlanglet/twig-cs-fixer": "^3.14"
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "docker": true,
            "require": "7.4.*"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        }
    }
}
