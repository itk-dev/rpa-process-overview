{% extends 'base.html.twig' %}

{% block title %}{{ 'Overview {label}'|trans({name: overview.label}) }}{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        addEventListener('load', () => {
            fetch({{ data_url|json_encode|raw }})
                .then(res => res.json())
                .then(data => {
                    console.log(data)
                    const el = document.createElement('pre');
                    el.innerText = JSON.stringify(data, null, 2);
                    document.body.appendChild(el);
                })
        })
    </script>
{% endblock %}

{% block content %}
    <a href="{{ data_url }}">{{ data_url }}</a>
{% endblock %}
